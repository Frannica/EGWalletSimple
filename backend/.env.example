# ====================
# Server Configuration
# ====================
NODE_ENV=development
PORT=4000

# ====================
# Security
# ====================
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_in_production
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d

# ====================
# Freshdesk Integration
# ====================
FRESHDESK_DOMAIN=yourdomain.freshdesk.com
FRESHDESK_API_KEY=your_freshdesk_api_key_here
FRESHDESK_EMAIL_CONFIG_ID=default

# ====================
# Rate Limiting
# ====================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AI_CHAT_RATE_LIMIT=10
AUTH_RATE_LIMIT=5

# ====================
# Logging
# ====================
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
AUDIT_LOG_PATH=./logs/audit.log
ERROR_LOG_PATH=./logs/error.log

# ====================
# CORS
# ====================
ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081,exp://192.168.1.100:19000

# ====================
# Security Headers
# ====================
ENABLE_HELMET=true
ENABLE_STRICT_CSP=false

# ====================
# Database
# ====================
DB_FILE_PATH=./db.json
DB_BACKUP_PATH=./db.json.bak
AUTO_BACKUP_INTERVAL_MS=3600000

# ====================
# Audit & Compliance
# ====================
ENABLE_AUDIT_LOGS=true
MAX_AUDIT_LOGS_MEMORY=10000
ENABLE_GDPR_FEATURES=true

# ====================
# Fraud Detection
# ====================
FRAUD_VELOCITY_THRESHOLD=5
FRAUD_AMOUNT_THRESHOLD_USD=1000
FRAUD_TIME_WINDOW_MS=3600000
ENABLE_VELOCITY_CHECKS=true

# ====================
# Email Configuration
# ====================
EMAIL_FROM=noreply@egwallet.com
EMAIL_SUPPORT=support@egwallet.com
EMAIL_SECURITY=security@egwallet.com
EMAIL_COMPLIANCE=compliance@egwallet.com

# ====================
# Webhooks
# ====================
WEBHOOK_SECRET=your_webhook_secret_key_here
ENABLE_WEBHOOK_VALIDATION=true

# ====================
# Feature Flags
# ====================
ENABLE_2FA=true
ENABLE_BIOMETRIC=true
ENABLE_AUTO_FRAUD_DETECTION=true
ENABLE_TRANSACTION_REVERSAL=true

# ====================
# Monitoring & Health
# ====================
ENABLE_HEALTH_CHECK=true
HEALTH_CHECK_INTERVAL_MS=60000
