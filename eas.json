{
  "cli": {
    "version": ">= 5.9.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "gradleCommand": ":app:assembleDebug",
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "env": {
          "NODE_OPTIONS": "--max-old-space-size=4096"
        }
      },
      "ignore": ["__tests__"]
    }
  },
  "submit": {
    "production": {}
  }
}
