{
    "compilerOptions":  {
                            "target":  "ES2020",
                            "module":  "ESNext",
                            "lib":  [
                                        "ES2020"
                                    ],
                            "jsx":  "react",
                            "moduleResolution":  "node",
                            "allowJs":  true,
                            "noEmit":  true,
                            "isolatedModules":  true,
                            "esModuleInterop":  true,
                            "skipLibCheck":  true,
                            "strict":  true,
                            "resolveJsonModule":  true,
                            "types":  [
                                          "react",
                                          "react-native"
                                      ]
                        },
    "exclude":  [
                    "node_modules",
                    "babel.config.js",
                    "metro.config.js",
                    "jest.config.js",
                    "jest.config.cjs",
                    "__tests__"
                ]
}
